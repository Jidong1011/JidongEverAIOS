.topbar {
  position: sticky;
  top: 0;
  z-index: 30;
  backdrop-filter: blur(18px);
  background: rgba(5, 7, 13, .74);
  border-bottom: 1px solid rgba(255, 255, 255, .14);
}

.topbar-inner {
  height: 136rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.logo {
  width: 84rpx;
  height: 84rpx;
  border: 1px solid rgba(216, 183, 106, .55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d8b76a;
  font-weight: 800;
  background: radial-gradient(circle, rgba(216, 183, 106, .16), rgba(255, 255, 255, .02));
  margin-left: 25rpx;
}

.brand-title {
  font-weight: 800;
}

.brand-sub {
  font-size: 24rpx;
  color: rgba(245, 241, 232, .72);
}

.badge {
  border: 1px solid rgba(216, 183, 106, .42);
  color: #d8b76a;
  border-radius: 999px;
  padding: 16rpx 24rpx;
  background: rgba(216, 183, 106, 0.05);
  font-size: 26rpx;
}
