<view class="bottom-nav">
  <view class="inner">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="nav-item {{selected === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text class="nav-icon">{{item.icon}}</text>
      <text class="nav-text">{{item.text}}</text>
    </view>
  </view>
</view>
