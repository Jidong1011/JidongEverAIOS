.benefits-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: radial-gradient(circle at top, #14294d 0%, var(--bg) 46%, #020309 100%);
  padding-bottom: 120rpx;
}

.benefits-header {
  position: sticky;
  top: 0;
  z-index: 30;
  text-align: center;
  padding: 80rpx 0 10rpx;
  background: rgba(11, 21, 39, 0.88);
  backdrop-filter: blur(18px);
}

.benefits-title {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--text);
}

.benefits-subtitle {
  font-size: 26rpx;
  color: var(--muted);
  letter-spacing: 0.18em;
  margin-top: 12rpx;
}

.tabs {
  display: flex;
  gap: 0;
  margin: 20rpx 48rpx 10rpx;
  border: 1px solid var(--line);
  border-radius: 999rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.03);
  transition: all 0.3s;
}

.tab-active {
  color: #17120a;
  background: linear-gradient(135deg, var(--gold), #f5dfa0);
}

.benefits-content {
  flex: 1;
  padding: 10rpx 48rpx;
}

.benefit-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  border: 1px solid var(--line);
  border-radius: 40rpx;
  padding: 36rpx;
  background: rgba(255, 255, 255, 0.045);
  margin-bottom: 24rpx;
}

.benefit-card.highlight {
  border-color: rgba(216, 183, 106, 0.35);
  background: linear-gradient(135deg, rgba(216, 183, 106, 0.1), rgba(101, 228, 255, 0.04));
}

.benefit-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 1px solid rgba(216, 183, 106, 0.45);
  background: rgba(216, 183, 106, 0.08);
  flex-shrink: 0;
}

.benefit-info {
  flex: 1;
  min-width: 0;
}

.benefit-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text);
  margin-bottom: 8rpx;
}

.benefit-desc {
  font-size: 26rpx;
  color: var(--muted);
  line-height: 1.6;
}

.benefits-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(5, 7, 13, 0.92);
  backdrop-filter: blur(18px);
  border-top: 1px solid var(--line);
}

.btn-upgrade {
  flex: 1;
  height: 96rpx !important;
  border-radius: 999rpx !important;
  background: linear-gradient(135deg, var(--gold), #f5dfa0) !important;
  color: #17120a !important;
  font-size: 32rpx !important;
  font-weight: 700 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border: none !important;
  box-shadow: 0 20rpx 60rpx rgba(216, 183, 106, 0.25) !important;
  min-width: 80%;
}

.btn-upgrade::after {
  border: none !important;
}

.btn-back {
  flex: 1;
  height: 96rpx !important;
  border-radius: 999rpx !important;
  border: 1rpx solid var(--line) !important;
  background: rgba(255, 255, 255, 0.06) !important;
  color: var(--text) !important;
  font-size: 32rpx !important;
  font-weight: 700 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.btn-back::after {
  border: none !important;
}

.pay-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.pay-dialog {
  width: 100%;
  background: #1a1d28;
  border-radius: 40rpx 40rpx 0 0;
  border-top: 1px solid rgba(216, 183, 106, 0.3);
  padding: 48rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  position: relative;
}

.pay-close {
  position: absolute;
  top: 32rpx;
  right: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  font-size: 36rpx;
}

.pay-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text);
  text-align: center;
  margin-bottom: 40rpx;
}

.pay-body {
  margin-bottom: 40rpx;
}

.pay-grade-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--gold);
  text-align: center;
  margin-bottom: 16rpx;
}

.pay-grade-price {
  text-align: center;
  margin-bottom: 36rpx;
}

.pay-rmb {
  font-size: 32rpx;
  color: #ff7a7a;
  font-weight: bold;
}

.pay-price-num {
  font-size: 72rpx;
  color: #ff7a7a;
  font-weight: bold;
}

.pay-period {
  font-size: 28rpx;
  color: var(--muted);
  margin-left: 8rpx;
}

.pay-grade-info {
  border: 1px solid var(--line);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.04);
}

.pay-info-item {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.pay-info-item:last-child {
  margin-bottom: 0;
}

.pay-info-label {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text);
  flex-shrink: 0;
}

.pay-info-value {
  font-size: 28rpx;
  color: var(--muted);
}

.pay-coupon-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 32rpx;
  border: 1px solid rgba(216, 183, 106, 0.35);
  border-radius: 24rpx;
  background: rgba(216, 183, 106, 0.06);
  margin-bottom: 24rpx;
}

.pay-coupon-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2px solid var(--line);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  flex-shrink: 0;
}

.pay-coupon-check.checked {
  background: var(--gold);
  border-color: var(--gold);
  color: #17120a;
}

.pay-coupon-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.pay-coupon-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff7a7a;
}

.pay-real-amount {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 16rpx 0;
}

.pay-real-label {
  font-size: 30rpx;
  color: var(--muted);
}

.pay-real-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff7a7a;
}

.pay-action {
  margin-top: 20rpx;
}

.pay-btn {
  width: 100% !important;
  height: 96rpx !important;
  border-radius: 999rpx !important;
  background: linear-gradient(135deg, var(--gold), #f5dfa0) !important;
  color: #17120a !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border: none !important;
  box-shadow: 0 20rpx 60rpx rgba(216, 183, 106, 0.25) !important;
}

.pay-btn::after {
  border: none !important;
}
