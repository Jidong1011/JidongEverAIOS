<topbar title="今日情报" subtitle="DAILY INTELLIGENCE"  />
<view class="page-body">
  <view class="container">
  <view class="page-title">

    <!-- <view class="h1">今日情报已送达</view> -->
    <view class="kicker">每天 8 点 · 只讲与云南有关的 AI</view>
    <view class="date-pill">{{today}} · 今日 {{articles.length}} 条</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="h2"></view>
      <text class="small" bindtap="goReportList">往期 →</text>
    </view>

    <view class="card news-card" wx:for="{{articles}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view>
        <text class="tag">{{item.categoryName || '日报'}}</text>
      </view>
      <view>
        <view class="h4">{{item.title}}</view>
        <view class="p">{{item.brief}}</view>
      </view>
    </view>

    <view class="loading-tip" wx:if="{{articles.length === 0}}">暂无文章</view>
  </view>

  <view class="section" wx:if="{{pastArticles.length > 0}}">
    <view class="h2">往期日报</view>
    <view class="list">
      <view class="list-item" wx:for="{{pastArticles}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <text class="bold">{{item.fmtDate}}</text>
        <text>{{item.title}}</text>
      </view>
    </view>
  </view>
</view>
</view>
